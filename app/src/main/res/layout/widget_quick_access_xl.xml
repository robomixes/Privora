<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="6dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:id="@+id/btn_camera"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        <ImageView
            android:id="@+id/icon_camera"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_camera"
            android:contentDescription="@string/feature_camera" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feature_camera"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_vault"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        <ImageView
            android:id="@+id/icon_vault"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_vault"
            android:contentDescription="@string/feature_vault" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feature_vault"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_notes"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        <ImageView
            android:id="@+id/icon_notes"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_note"
            android:contentDescription="@string/feature_notes" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feature_notes"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_reminders"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        <ImageView
            android:id="@+id/icon_reminders"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_reminder"
            android:contentDescription="@string/widget_reminders_label" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_reminders_label"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
